# GEMINI_API_KEY: Necessário para chamadas da API Gemini AI.
# O AI Studio injeta isso automaticamente em tempo de execução a partir dos segredos do usuário.
# Os usuários configuram isso através do painel de Segredos na interface do AI Studio.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: A URL onde este aplicativo está hospedado.
# O AI Studio injeta isso automaticamente em tempo de execução com a URL do serviço Cloud Run.
# Usado para links autorreferentes, callbacks OAuth e endpoints da API.
APP_URL="MY_APP_URL"
